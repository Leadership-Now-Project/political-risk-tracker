# Anthropic API key for custom event evaluation
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Admin Panel
# Generate password hash: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('your-password').digest('hex'))"
ADMIN_PASSWORD_HASH=
JWT_SECRET=

# GitHub API (for admin data mutations on Vercel's read-only filesystem)
# Create a fine-grained token with Contents read/write on the repo
GITHUB_TOKEN=
GITHUB_REPO=Leadership-Now-Project/political-risk-tracker
